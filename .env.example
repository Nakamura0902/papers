# === データベース（Supabase Postgres）===
# Supabase ダッシュボード上部の「Connect」→ ORMs → Prisma からコピー
# アプリ実行用（トランザクションプーラー : ポート 6543）
DATABASE_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-...pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# マイグレーション用（セッションプーラー : ポート 5432）
DIRECT_URL="postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-...pooler.supabase.com:5432/postgres"

# === セッション（ログイン）===
# 長いランダム文字列（本番では必ず固有の値に）。生成: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET="change-me-to-a-long-random-string"

# === Supabase Storage（PDF保存）===
# Settings → API
SUPABASE_URL="https://xxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"
# 保存先バケット名（任意・既定は pdfs）
# SUPABASE_PDF_BUCKET="pdfs"

# === PDF に印字する会社情報（任意）===
# COMPANY_NAME="株式会社サンプル"
# COMPANY_ADDRESS="東京都千代田区サンプル1-2-3"
# COMPANY_PHONE="03-0000-0000"
# COMPANY_REP="代表取締役 山田 花子"
